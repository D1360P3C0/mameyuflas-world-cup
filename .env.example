# ============================================
# MAMEYUFLAS WORLD CUP — Variables de Entorno
# ============================================
# Copiar como .env.local y rellenar los valores reales.
# NUNCA commitear .env.local al repositorio.

# -----------------------------------------------
# SUPABASE — Obligatorias
# -----------------------------------------------
# URL del proyecto (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://[TU-PROJECT-ID].supabase.co

# Clave anon pública (Project Settings > API > anon public)
# Segura para el cliente — RLS protege los datos
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave service_role — NUNCA en NEXT_PUBLIC_, NUNCA en el cliente
# Solo para Server Actions de admin. (Project Settings > API > service_role)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ID del proyecto Supabase (para generar tipos con supabase CLI)
SUPABASE_PROJECT_ID=tu-project-id

# -----------------------------------------------
# SUPABASE — Desarrollo local con supabase start
# -----------------------------------------------
# Descomentar solo si usas Supabase local:
# NEXT_PUBLIC_SUPABASE_URL=http://localhost:54321
# NEXT_PUBLIC_SUPABASE_ANON_KEY=[anon key local del output de supabase start]

# -----------------------------------------------
# APP
# -----------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000

# -----------------------------------------------
# APIS EXTERNAS
# -----------------------------------------------
# API-Football (RapidAPI) — datos de partidos, goleadores, asistentes
# Obtener en: https://rapidapi.com/api-sports/api/api-football
API_FOOTBALL_KEY=

# Liga Mundial 2026 en API-Football
# Por defecto: league_id=1, season=2026 (ver lib/constants/api-football.ts)

# Secreto para autenticar los cron jobs de Vercel
# Generar con: openssl rand -base64 32
CRON_SECRET=

# NewsAPI para noticias deportivas (Fase futura)
# NEWS_API_KEY=

# -----------------------------------------------
# MONITOREO (Fase 7 — Producción)
# -----------------------------------------------
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
